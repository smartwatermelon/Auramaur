# =====================================================================
# Claude (LLM analyzer)
# =====================================================================
# The bot calls the `claude` CLI as a subprocess — see
# auramaur/nlp/analyzer.py:_call_claude_cli. It does NOT use the
# Anthropic SDK directly. Auth is whatever `claude` is configured with.
# For long-lived non-interactive use (servers, containers, agents),
# generate a token with `claude setup-token` and export it as:
#
CLAUDE_CODE_OAUTH_TOKEN=
#
# The two settings below are declared in config/settings.py for legacy
# reasons but are not consumed anywhere in the codebase. Leave them
# blank unless you intend to revive direct-SDK calls.
ANTHROPIC_API_KEY_PRIMARY=
ANTHROPIC_API_KEY_SECONDARY=

# =====================================================================
# Kalshi (Phase 1 target — see docs/plans/2026-04-28-deployment-plan.md)
# =====================================================================
# Both required for Kalshi market discovery and trading. The private
# key is an RSA PEM file that Kalshi issued when you created the API
# key; KALSHI_PRIVATE_KEY_PATH points to where it lives on disk.
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=

# =====================================================================
# Polymarket (Phase 2 / Phase 3)
# =====================================================================
POLYGON_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PROXY_ADDRESS=

# =====================================================================
# Data Sources
# =====================================================================
# All optional but improve coverage. Without them the bot falls back
# to the no-key sources (RSS, web search, GDELT, Google Trends,
# Bluesky, Manifold, Metaculus, USGS, CoinGecko, HackerNews, ESPN).
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=auramaur/0.1
TWITTER_BEARER_TOKEN=
FRED_API_KEY=

# =====================================================================
# Alerts (optional)
# =====================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# =====================================================================
# Safety
# =====================================================================
AURAMAUR_LIVE=false
AURAMAUR_ENABLE_REDEMPTION=false
